# Password everyone enters to join the watch party
SITE_PASSWORD=your_password_here

# Long random string used to sign JWT tokens — keep this secret
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Port the server listens on
PORT=3001

# URL of the client — used for CORS
# In development this is always http://localhost:5173
# In production set this to your deployed URL e.g. https://your-app.railway.app
CLIENT_ORIGIN=http://localhost:5173
